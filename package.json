        "@sveltejs/vite-plugin-svelte": "^5.0.3",
        "@tailwindcss/forms": "^0.5.9",
        "@tailwindcss/typography": "^0.5.15",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/svelte": "^5.2.4",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "bits-ui": "^2.17.3",
